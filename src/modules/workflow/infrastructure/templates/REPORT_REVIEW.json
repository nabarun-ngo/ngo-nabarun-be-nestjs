{
  "$schema": "./workflow-schema.json",
  "name": "Report Review and Approval",
  "description": "Workflow for reviewing and approving reports generated by the system.",
  "fields": [
    {
      "key": "reportCode",
      "defKey": "INPUT_TEXT_FIELD",
      "label": "Report Code",
      "mandatory": true
    },
    {
      "key": "reportName",
      "defKey": "INPUT_TEXT_FIELD",
      "label": "Report Name",
      "mandatory": true
    },
    {
      "key": "reportId",
      "defKey": "INPUT_TEXT_FIELD",
      "label": "Report ID",
      "mandatory": true
    }
  ],
  "preCreationTasks": [],
  "steps": [
    {
      "isDefault": true,
      "stepId": "review",
      "name": "Report Approval",
      "description": "Review auto-generated {{reportName}} correct if required and Approve.",
      "tasks": [
        {
          "taskId": "approve_report",
          "name": "Review & Approve {{reportName}}",
          "description": "Review {{reportName}} and provide your approval decision.",
          "type": "MANUAL",
          "etaHours": 24,
          "taskDetail": {
            "assignedTo": {
              "roleGroups": [],
              "roleNames": "{{roleNames}}"
            },
            "isAutoCloseable": true,
            "autoCloseRefId": "{{reportId}}",
            "autoCloseEventName": "ReportApprovedEvent",
            "autoCloseCondition": "status == 'APPROVED'",
            "autoCloseResultData": {
              "reportReady": "Yes"
            },
            "checklist": [
              "Click <a href=\"https://nabarun-frontend-dev.vercel.app/reports\">here</a> to view all reports",
              "Identify the report: {{reportId}}",
              "Download and verify if the auto-generated {{reportName}} is correct.",
              "In case any correction is required, Fix the same and regenerate the report.",
              "Click on Approve Button."
            ],
            "fields": [
              {
                "key": "reportReady",
                "defKey": "SELECT_YES_NO_FIELD",
                "label": "Is '{{reportName}}' ready to publish?",
                "mandatory": true
              }
            ]
          }
        }
      ],
      "transitions": [
        {
          "condition": "step_review_task_approve_report.reportReady == 'Yes'",
          "nextStepId": null
        },
        {
          "condition": "step_review_task_approve_report.reportReady == 'No'",
          "nextStepId": "review"
        },
        {
          "condition": "default",
          "nextStepId": "review"
        }
      ]
    }
  ]
}